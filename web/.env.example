# Copy to ".env" in this folder. Get values from Supabase → Project Settings → API.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Web Push (browser notifications) — public key only in the app.
# Generate pair: npx --yes web-push generate-vapid-keys
# Put the public key here; put BOTH keys in Supabase Edge Function secrets (VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY).
VITE_VAPID_PUBLIC_KEY=

# Email + scheduled reminders use Supabase Edge Functions — set RESEND_API_KEY and VAPID_* as function secrets (not in Vite).
